# AQI Health Alert System — Environment Variables
# Copy this file to .env and fill in your real values.
# In Railway: set these under Project → Variables (not committed to git).

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here     # service_role key — NEVER expose publicly

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash, no spaces)
# Example: https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=https://your-app.vercel.app

# ─── AQI Data Sources ─────────────────────────────────────────────────────────
WAQI_TOKEN=your_waqi_token_here          # https://aqicn.org/data-platform/token/
OPENAQ_API_KEY=your_openaq_api_key_here  # https://explore.openaq.org
OWM_API_KEY=your_owm_api_key_here        # https://openweathermap.org/api

# ─── Alert Channels ────────────────────────────────────────────────────────────
# Twilio SMS — https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# SendGrid Email — https://app.sendgrid.com → Settings → API Keys
# SENDGRID_FROM_EMAIL must be a verified sender in SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# ─── Model Artifact Paths ─────────────────────────────────────────────────────
MODEL_PATH=aqi_lstm.h5
SCALER_PATH=scaler.pkl
METADATA_PATH=model_metadata.json
BASELINE_PATH=seasonal_baseline.json
RISK_MODEL_PATH=risk_model.pkl
RISK_ENCODER_PATH=risk_label_encoder.pkl
RISK_METADATA_PATH=risk_model_metadata.json
