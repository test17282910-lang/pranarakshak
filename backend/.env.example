# AQI Health Alert System — Environment Variables
# Copy this file to .env and fill in your keys

# ─── Supabase Database ─────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here     # NEVER expose this publicly

# ─── AQI Data Sources ──────────────────────────────
# OpenAQ API Key (free at https://explore.openaq.org)
OPENAQ_API_KEY=your_openaq_api_key_here

# OpenWeatherMap API Key (free at https://openweathermap.org/api)
OWM_API_KEY=your_owm_api_key_here

# ─── Alert Channels ────────────────────────────────
# Twilio (SMS) — twilio.com
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# SendGrid (Email) — sendgrid.com
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# ─── Model Artifact Paths ──────────────────────────
MODEL_PATH=aqi_lstm.h5
SCALER_PATH=scaler.pkl
METADATA_PATH=model_metadata.json
BASELINE_PATH=seasonal_baseline.json
