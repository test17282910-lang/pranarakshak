# ── Secrets & Environment Variables (NEVER commit these) ──────────────────────
backend/.env
frontend-next/.env.local
frontend-next/.env*.local
*.env

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
venv/
.venv/
env/
*.egg-info/
dist/
build/
.eggs/

# ── ML Model Artifacts (committed for Railway deployment) ─────────────────────
# Note: These are needed for production. If files grow too large (>100MB),
# consider using Git LFS or cloud storage instead.
!backend/aqi_lstm.h5
!backend/scaler.pkl
!backend/model_metadata.json
!backend/seasonal_baseline.json
!backend/risk_model.pkl
!backend/risk_label_encoder.pkl
!backend/risk_model_metadata.json
# Still ignore other generated files:
backend/*.keras
backend/demo_*.json

# ── Next.js / Node ─────────────────────────────────────────────────────────────
frontend-next/node_modules/
frontend-next/.next/
frontend-next/out/
frontend-next/.vercel/
node_modules/

# ── IDE & OS ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ── Scratch / test files (keep test scripts but not generated data) ────────────
backend/scratch/*.csv
backend/scratch/*.json
